# Prompt Reconstruction Engine — backend environment
# Copy to .env on the VPS (chmod 600). NEVER commit the real key.
OPENROUTER_API_KEY=sk-or-v1-...
RECON_PORT=8791
RECON_RATE_LIMIT=20
RECON_DAILY_CAP=500

# Deep-research dispatch (POST /research → perplexity/sonar-deep-research).
# DISABLED unless RESEARCH_TOKEN is set, so a paid Perplexity call can never be
# triggered by an anonymous visitor. Send it as `Authorization: Bearer <token>`.
# Leave blank to keep /research off.
RESEARCH_TOKEN=
RESEARCH_MODEL=perplexity/sonar-deep-research
